<% content_for :title, "serviços | Hiperion Serras" %>
<% content_for :meta_description, "Conheca os serviços tecnicos especializados da Hiperion Serras para Serras Circulares e Laminas de Serra Fita com qualidade, precisao e suporte tecnico dedicado." %>
<% content_for :body_class, "services-page" %>

<section id="services-hero" class="services-banner" aria-label="Banner da pagina de serviços">
  <div class="services-banner__content w-100">
    <h1 class="services-banner__title text-center">
      Serviços de afiação industrial e manutenção de serras circulares
    </h1>

    <nav class="services-banner__breadcrumb" aria-label="Navegacao estrutural">
      <ol class="services-banner__breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <%= link_to "HOME", root_path, class: "services-banner__breadcrumb-link", itemprop: "item" %>
          <meta itemprop="name" content="Home" />
          <meta itemprop="position" content="1" />
        </li>
        <li class="services-banner__breadcrumb-separator" aria-hidden="true">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="services-banner__breadcrumb-current" itemprop="name">SERVIÇOS</span>
          <meta itemprop="position" content="2" />
        </li>
      </ol>
    </nav>
  </div>
</section>

<section class="services-list" aria-labelledby="services-list-heading">
  <div class="container">
    <h2 id="services-list-heading" class="visually-hidden">Lista de serviços</h2>

    <% if user_signed_in? %>
      <div class="services-list__top-actions">
        <%= link_to "Novo serviço", new_secret_service_path, class: "black-btn" %>
      </div>
    <% end %>

    <% if @services.any? %>
      <div class="services-list__grid">
        <% @services.each do |service| %>
          <article class="services-list__card">
            <%= link_to service_path(service), class: "services-list__link", aria: { label: "Ver detalhes do serviço #{service.name}" } do %>
              <div class="services-list__image-wrapper">
                <% if service.thumbnail.attached? %>
                  <%= image_tag service.thumbnail, class: "services-list__image", alt: service.name %>
                <% elsif service.image.attached? %>
                  <%= image_tag service.image, class: "services-list__image", alt: service.name %>
                <% else %>
                  <div class="services-list__image services-list__image--placeholder" aria-hidden="true"></div>
                <% end %>
              </div>
              <h3 class="services-list__name"><%= service.name %></h3>
            <% end %>

            <% if user_signed_in? %>
              <div class="services-list__admin-actions">
                <%= link_to "Editar", edit_secret_service_path(service), class: "secondary-btn" %>
                <%= link_to "Excluir",
                  secret_service_path(service),
                  data: { turbo_method: :delete, turbo_confirm: "Deseja realmente excluir este serviço?" },
                  class: "black-btn" %>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="services-list__empty">Ainda nao ha serviços disponiveis...</p>
    <% end %>
  </div>
</section>

<%= render "shared/category_showcase",
  title: "Conheça nossos produtos",
  subtitle: "Soluções completas em Lâminas de Serra Fita Eberle e Serras Circulares.",
  cards: [
    {
      image: "carousel/banner-2x-0.png",
      name: "LÂMINAS DE SERRA FITA",
      cta_text: "CONHEÇA NOSSAS LÂMINAS DE SERRA FITA",
      cta_url: band_saw_products_path,
      aria_label: "Saiba mais sobre as lâminas de serra fita da Hiperion Serras"
    },
    {
      image: "carousel/banner-2x-1.png",
      name: "SERRAS CIRCULARES",
      cta_text: "CONHEÇA NOSSAS SERRAS CIRCULARES",
      cta_url: circular_saw_products_path,
      aria_label: "Saiba mais sobre as serras circulares da Hiperion Serras"
    }
  ] %>
