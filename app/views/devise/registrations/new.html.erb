<% content_for :title, "Cadastro | Hiperion Serras" %>
<% content_for :body_class, "login-page" %>

<section class="login" aria-labelledby="login-heading">
  <div class="login__image" aria-hidden="true"></div>

  <div class="login__panel">
    <div class="login__panel-inner">
      <div class="login__logo">
        <%= link_to root_path, class: "login__logo-link", aria: { label: "Ir para página inicial" } do %>
          <%= image_tag "logo-nav-2x.png", alt: "Hiperion Serras", class: "login__logo-image" %>
        <% end %>
      </div>

      <h1 id="login-heading" class="login__title">Painel Administrativo</h1>
      <p class="login__subtitle">Cadastre um usuário para gerenciar o conteúdo</p>

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name, admin: params[:admin]), html: { class: "login__form" }) do |f| %>
        <%= f.error_notification %>

        <div class="login__field">
          <%= f.label :email, "E-mail", class: "login__label" %>
          <%= f.input_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com", class: "login__input" %>
        </div>

        <div class="login__field">
          <%= f.label :password, "Senha", class: "login__label" %>
          <%= f.input_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "login__input" %>
        </div>

        <div class="login__field">
          <%= f.label :password_confirmation, "Confirmar senha", class: "login__label" %>
          <%= f.input_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "login__input" %>
        </div>

        <div class="login__actions">
          <%= f.button :submit, "Cadastrar", class: "login__submit" %>
        </div>
      <% end %>

      <div class="login__links">
        <%= link_to "Voltar para login", new_session_path(resource_name), class: "login__link" %>
      </div>
    </div>
  </div>
</section>
