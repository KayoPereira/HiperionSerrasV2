<%= form_with model: [:secret, @product], class: "product-admin-form", local: true do |f| %>
  <% if @product.errors.any? %>
    <div class="product-admin-form__errors" role="alert" aria-live="polite">
      <p>Verifique os campos abaixo:</p>
      <ul>
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="product-admin-form__field">
    <%= f.label :product_type, "Tipo de produto" %>
    <%= f.select :product_type, Product.product_types.keys.map { |type| [Product.human_enum_name(:product_type, type), type] }, { selected: @product.product_type || Product.product_types.keys.first }, { required: true } %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :application_type, "Tipo de aplicação" %>
    <%= f.select :application_type, Product.application_types.keys.map { |type| [Product.human_enum_name(:application_type, type), type] }, {}, { required: true } %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :name, "Nome" %>
    <%= f.text_area :name, rows: 2, required: true %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :description, "Descrição (texto rico)" %>
    <%= f.rich_text_area :description, required: true %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :video_url, "URL do vídeo YouTube (opcional)" %>
    <%= f.text_field :video_url, placeholder: "https://youtube.com/watch?v=..." %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :thumbnail, "Thumbnail do banner" %>
    <%= f.file_field :thumbnail, accept: "image/*", required: !@product.thumbnail.attached? %>
    <% if @product.thumbnail.attached? %>
      <div class="product-admin-form__image-preview">
        <%= image_tag @product.thumbnail, alt: "Thumbnail do #{@product.name}" %>
      </div>
    <% end %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :images, "Imagens do produto (múltiplas)" %>
    <%= f.file_field :images, accept: "image/*", multiple: true %>
    <% if @product.images.attached? %>
      <div class="product-admin-form__images-preview">
        <% @product.images.each_with_index do |image, index| %>
          <div class="product-admin-form__image-item">
            <%= image_tag image, alt: "#{@product.name} - Imagem #{index + 1}" %>
            <label class="product-admin-form__image-remove">
              <input type="checkbox" name="remove_images[]" value="<%= image.id %>">
              Remover
            </label>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :gallery, "Gallery (múltiplas imagens)" %>
    <%= f.file_field :gallery, accept: "image/*", multiple: true %>
    <% if @product.gallery.attached? %>
      <div class="product-admin-form__images-preview">
        <% @product.gallery.each_with_index do |image, index| %>
          <div class="product-admin-form__image-item product-admin-form__image-item--gallery">
            <%= image_tag image, alt: "#{@product.name} - Gallery #{index + 1}" %>
            <label class="product-admin-form__image-remove product-admin-form__image-remove--overlay" aria-label="Remover imagem #{index + 1} da gallery">
              <input type="checkbox" name="remove_gallery[]" value="<%= image.id %>">
              <span class="product-admin-form__image-remove-icon" aria-hidden="true">x</span>
            </label>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="product-admin-form__field">
    <%= f.label :image_detail, "Imagem de detalhe (opcional)" %>
    <%= f.file_field :image_detail, accept: "image/*" %>
    <% if @product.image_detail.attached? %>
      <div class="product-admin-form__image-preview">
        <%= image_tag @product.image_detail, alt: "Detalhe do #{@product.name}" %>
      </div>
    <% end %>
  </div>

  <fieldset class="product-admin-form__faq-fieldset" data-controller="service-faqs">
    <legend>Perguntas frequentes</legend>

    <div class="product-admin-form__faq-list" data-service-faqs-target="list">
      <%= f.fields_for :product_faqs do |faq_fields| %>
        <%= render "product_faq_fields", faq_fields: faq_fields %>
      <% end %>
    </div>

    <template data-service-faqs-target="template">
      <%= f.fields_for :product_faqs, ProductFaq.new, child_index: "NEW_RECORD" do |faq_fields| %>
        <%= render "product_faq_fields", faq_fields: faq_fields %>
      <% end %>
    </template>

    <div class="product-admin-form__faq-actions">
      <button type="button" class="black-btn" data-action="service-faqs#add">+ Adicionar FAQ</button>
    </div>
  </fieldset>

  <div class="product-admin-form__actions">
    <%= f.submit @product.persisted? ? "Atualizar produto" : "Criar produto", class: "black-btn" %>
    <%= link_to "Cancelar", circular_saw_products_path, class: "secondary-btn" %>
  </div>
<% end %>
