<footer class="hiperion-footer">
  <div class="hiperion-footer__main container" style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 10px;">
    <section class="hiperion-footer__brand">
      <%= image_tag "logo-nav-2x.png", class: "hiperion-footer__logo", alt: "Hiperion Serras" %>
      <p class="hiperion-footer__tagline">PRECISAO PARA CADA CORTE!</p>
    </section>

    <section class="hiperion-footer__menu">
      <h3 class="hiperion-footer__title">INSTITUCIONAL</h3>
      <ul>
        <li><%= link_to "QUEM SOMOS", about_path %></li>
        <li><%= link_to "CONTATO", contact_path %></li>
        <li><%= link_to "ORÇAMENTO", budget_path %></li>
      </ul>
    </section>

    <section class="hiperion-footer__menu">
      <h3 class="hiperion-footer__title">PRODUTOS E SERVIÇOS</h3>
      <ul>
        <li><a href="<%= circular_saw_products_path %>">SERRAS CIRCULARES</a></li>
        <li><%= link_to "SERVIÇOS", services_path %></li>
        <li><a href="<%= band_saw_products_path %>">LÂMINAS DE SERRA FITA</a></li>
      </ul>
    </section>

    <section class="hiperion-footer__contacts" style="width: 100%;">
      <h3 class="hiperion-footer__title">CONTATOS</h3>
      <ul>
        <li>
          <span class="hiperion-footer__contact-icon" aria-hidden="true">
            <i class="fa-brands fa-whatsapp"></i>
          </span>
          <a href="https://wa.me/5519971994133" target="_blank" rel="noopener noreferrer">(19) 97199.4133</a>
        </li>
        <li>
          <span class="hiperion-footer__contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.34 1.78.65 2.63a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.45-1.22a2 2 0 0 1 2.11-.45c.85.31 1.73.53 2.63.65A2 2 0 0 1 22 16.92z" />
            </svg>
          </span>
          <a href="tel:+551938315457">(19) 3831.5457</a>
        </li>
        <li>
          <span class="hiperion-footer__contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" />
              <path d="m22 6-10 7L2 6" />
            </svg>
          </span>
          <a href="mailto:contato@hiperionserras.com.br">contato@hiperionserras.com.br</a>
        </li>
      </ul>

      <style>
        @media (min-width: 1920px) {
          .hiperion-footer__contacts {
            width: 330px !important;
          }
        }

        @media (min-width: 1200px) and (max-width: 1919px) {
          .hiperion-footer__contacts {
            width: 280px !important;
          }
        }

        @media (min-width: 768px) and (max-width: 1199px) {
          .hiperion-footer__contacts {
            width: 100% !important;
          }
        }

        @media (max-width: 767px) {
          .hiperion-footer__contacts {
            width: 100% !important;
          }
        }
      </style>
    </section>
  </div>

  <div class="hiperion-footer__locations container mb-4" style="display: grid; grid-template-columns: 1fr 2fr 1fr; gap: 10px;">
    <section>
      <h3 class="hiperion-footer__title">SIGA A GENTE!</h3>
      <div class="hiperion-footer__social">
        <a href="https://www.linkedin.com/company/hiperion-serras/" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
        </a>
        <a href="https://www.instagram.com/hiperionserras/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <i class="fa-brands fa-instagram" aria-hidden="true"></i>
        </a>
        <a href="https://www.facebook.com/hiperionserras/" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <i class="fa-brands fa-facebook" aria-hidden="true"></i>
        </a>
      </div>
    </section>

    <section class="hiperion-footer__location hiperion-footer__location--left">
      <h3 class="hiperion-footer__title">CENTRO DE DISTRIBUIÇÃO DE SERRAS<br> CIRCULARES E SERVIÇO DE AFIAÇÃO</h3>
      <p class="hiperion-footer__location-city mb-2">
        <%= image_tag "localização@2x.png", alt: "Localização", style: "width: 23px; height: 25px;" %>
        MOGI GUACU-SP
      </p>
      <a href="https://maps.app.goo.gl/3gC1ynHJ4doDNGnN9" target="_blank" rel="noopener noreferrer" class="hiperion-footer__location-link">
        <p>Rua Eli Paulo Colombo, 1470 - Jardim Sakaida<br> Mogi Guaçu-SP | CEP: 13.849-702</p>
      </a>

      <style>
        .hiperion-footer__location-link p {
          transition: color 0.3s ease;
        }

        .hiperion-footer__location-link:hover p {
          color: #D2AC47;
        }
      </style>
    </section>

    <section class="hiperion-footer__location hiperion-footer__location--right" style="width: 100%;">
      <h3 class="hiperion-footer__title">CENTRO DE DISTRIBUIÇÃO DE LÂMINAS DE SERRA FITA</h3>
      <p class="hiperion-footer__location-city mb-2">
        <%= image_tag "localização@2x.png", alt: "Localização", style: "width: 23px; height: 25px;" %>
        POA-SP
      </p>
      <a href="https://maps.app.goo.gl/DbPekvjr4ZcuSFGv5" target="_blank" rel="noopener noreferrer" class="hiperion-footer__location-link">
        <p>Avenida Getulio Vargas, 692 - Calmon Viana Poa-SP | CEP: 85.600-000</p>
      </a>

      <style>
        .hiperion-footer__location-link p {
          transition: color 0.3s ease;
        }

        .hiperion-footer__location-link:hover p {
          color: #D2AC47;
        }
      </style>
    </section>

    <style>
      @media (min-width: 1920px) {
        .hiperion-footer__location--right {
          width: 330px !important;
        }
      }

      @media (min-width: 1200px) and (max-width: 1919px) {
        .hiperion-footer__location--right {
          width: 280px !important;
        }
      }

      @media (min-width: 768px) and (max-width: 1199px) {
        .hiperion-footer__location--right {
          width: 100% !important;
        }
      }

      @media (max-width: 767px) {
        .hiperion-footer__location--right {
          width: 100% !important;
        }
      }
    </style>
  </div>

  <div class="hiperion-footer__bottom">
    <div class="container hiperion-footer__bottom-content">
      <p>© 2026 - Hiperion Serras - Todos os direitos reservados.</p>
      <nav class="hiperion-footer__legal-links" aria-label="Links legais">
        <%= link_to "Politica de Privacidade", privacy_policies_path, class: "text-decoration-none" %>
        <%= link_to "Politica de Cookies", cookies_policies_path, class: "text-decoration-none" %>
        <%= link_to "Termos de Uso", terms_of_use_path, class: "text-decoration-none" %>
      </nav>
      <div class="hiperion-footer__developed-by">
        <span>Site desenvolvido por:</span>
        <a href="https://agenciamove.com.br/"><%= image_tag "footer/developed_by/move.png", alt: "Desenvolvido por" %></a>
        <a href="https://devrec.com.br" target="blank"><%= image_tag "footer/developed_by/devrec.png", alt: "Desenvolvido por" %></a>
      </div>
    </div>
  </div>
</footer>
