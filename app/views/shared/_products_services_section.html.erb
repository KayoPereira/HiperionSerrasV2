<section class="products-services-section" aria-labelledby="products-services-heading">
  <div class="products-services-section__container container">
    <h2 id="products-services-heading" class="products-services-section__title">
      Conheça nossos produtos e serviços
    </h2>
    <p class="products-services-section__subtitle">
      Soluções completas em serras circulares, lâminas de serra fita e serviços técnicos especializados
    </p>

    <div class="products-services-section__grid">
      <% if !hide_serra_fita %>
        <article class="products-services-section__card" role="img" aria-label="Lâminas de Serra Fita para diferentes aplicações industriais">
          <div class="products-services-section__card-image" style="background-image: linear-gradient(135deg, rgba(9, 19, 39, 0.65) 0%, rgba(9, 19, 39, 0.4) 100%), url('<%= asset_path('offers/serra_fita-2x.png') %>'); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="products-services-section__card-content">
              <h3 class="products-services-section__card-title">LÂMINAS DE SERRA FITA</h3>
              <p class="products-services-section__card-description">
                Soluções em lâminas de serra fita de alta performance para corte de metais, não ferrosos e derivados
              </p>
              <%= link_to "CONHEÇA NOSSAS LÂMINAS DE SERRA FITA", "#",
                    class: "secondary-btn py-2",
                    style: "font-size: 11px;",
                    aria: { label: "Saiba mais sobre as lâminas de serra fita da Hiperion Serras" } %>
            </div>
          </div>
        </article>
      <% end %>

      <% if !hide_serras_circulares %>
        <article class="products-services-section__card" role="img" aria-label="Serras Circulares para diferentes aplicações industriais">
          <div class="products-services-section__card-image" style="background-image: linear-gradient(135deg, rgba(9, 19, 39, 0.65) 0%, rgba(9, 19, 39, 0.4) 100%), url('<%= asset_path('offers/serra_circular-2x.png') %>'); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="products-services-section__card-content">
              <h3 class="products-services-section__card-title">SERRAS CIRCULARES</h3>
              <p class="products-services-section__card-description">
                Serras circulares de precisão com alto desempenho para metais, madeira e outras aplicações especiais
              </p>
              <%= link_to "CONHEÇA NOSSAS SERRAS CIRCULARES", "#",
                    class: "secondary-btn py-2",
                    style: "font-size: 11px;",
                    aria: { label: "Saiba mais sobre as serras circulares da Hiperion Serras" } %>
            </div>
          </div>
        </article>
      <% end %>

      <% if !hide_servicos %>
        <article class="products-services-section__card" role="img" aria-label="Serviços técnicos especializados da Hiperion Serras">
          <div class="products-services-section__card-image" style="background-image: linear-gradient(135deg, rgba(9, 19, 39, 0.65) 0%, rgba(9, 19, 39, 0.4) 100%), url('<%= asset_path('offers/servicos-2x.png') %>'); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="products-services-section__card-content">
              <h3 class="products-services-section__card-title">SERVIÇOS</h3>
              <p class="products-services-section__card-description">
                Serviços técnicos especializados incluindo afiação, revisão e manutenção de serras industriais
              </p>
              <%= link_to "CONHEÇA NOSSOS SERVIÇOS", "#",
                    class: "secondary-btn py-2",
                    style: "font-size: 11px;",
                    aria: { label: "Saiba mais sobre os serviços técnicos da Hiperion Serras" } %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>
