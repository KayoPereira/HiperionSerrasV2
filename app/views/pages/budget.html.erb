<% content_for :title, "Orçamento | Hiperion Serras" %>
<% content_for :meta_description, "Solicite um orçamento com a Hiperion Serras para lâminas de serra fita, serras circulares e serviços técnicos especializados para sua operação." %>
<% content_for :body_class, "budget-page" %>

<section class="budget-hero" aria-labelledby="budget-hero-heading">
  <div class="budget-hero__media">
    <div class="budget-hero__overlay"></div>
    <div class="budget-hero__content">
      <h1 id="budget-hero-heading" class="budget-hero__title">
        Seu processo merece a escolha certa. Solicite seu orçamento com quem entende do assunto.
      </h1>

      <nav class="budget-hero__breadcrumb" aria-label="Navegação estrutural">
        <ol class="budget-hero__breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <%= link_to "HOME", root_path, class: "budget-hero__breadcrumb-link", itemprop: "item" %>
            <meta itemprop="name" content="Home" />
            <meta itemprop="position" content="1" />
          </li>
          <li class="budget-hero__breadcrumb-separator" aria-hidden="true">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span class="budget-hero__breadcrumb-current" itemprop="name">ORÇAMENTO</span>
            <meta itemprop="position" content="2" />
          </li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="budget-hero__form-panel">
    <div class="budget-hero__form-inner">
      <h2 class="visually-hidden">Formulário de orçamento</h2>

      <%= form_with model: @budget_request,
        url: budget_requests_path,
        local: true,
        class: "budget-form",
        aria: { label: "Formulario de solicitacao de orcamento" },
        data: { controller: "cnpj-mask" } do |f| %>
        <% if @budget_request.errors.any? %>
          <div class="budget-form__errors" role="alert" aria-live="polite">
            <p>Verifique os campos abaixo:</p>
            <ul>
              <% @budget_request.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="budget-form__grid budget-form__grid--2 budget-form__grid--top-aligned">
          <div class="budget-form__field">
            <%= f.label :company_tax_id, "*CNPJ da sua empresa" %>
            <%= f.text_field :company_tax_id,
              required: true,
              inputmode: "numeric",
              autocomplete: "off",
              placeholder: "00.000.000/0000-00",
              maxlength: 18,
              aria: { describedby: "budget-cnpj-error" },
              data: {
                cnpj_mask_target: "input",
                action: "input->cnpj-mask#handleInput blur->cnpj-mask#validateField"
              } %>
            <p id="budget-cnpj-error" class="budget-form__field-error" data-cnpj-mask-target="error" hidden>
              Digite um CNPJ válido.
            </p>
          </div>

          <div class="budget-form__field">
            <%= f.label :company_name, "*Nome da empresa" %>
            <%= f.text_field :company_name, required: true, maxlength: 120 %>
          </div>
        </div>

        <div class="budget-form__grid budget-form__grid--2 budget-form__grid--top-aligned">
          <div class="budget-form__field">
            <%= f.label :business_segment, "*Qual o segmento da sua empresa?" %>
            <%= f.text_field :business_segment, required: true, maxlength: 120 %>
          </div>

          <div class="budget-form__field">
            <%= f.label :full_name, "*Seu nome" %>
            <%= f.text_field :full_name, required: true, autocomplete: "name", maxlength: 120 %>
          </div>
        </div>

        <div class="budget-form__grid budget-form__grid--2 budget-form__grid--top-aligned">
          <div class="budget-form__field">
            <%= f.label :phone, "*Telefone ou Celular" %>
            <%= f.telephone_field :phone,
              required: true,
              autocomplete: "tel",
              placeholder: "(19) 99999-9999",
              maxlength: 15,
              data: { controller: "phone-mask" } %>
          </div>

          <div class="budget-form__field" data-controller="email-validate">
            <%= f.label :email, "*Seu e-mail" %>
            <%= f.email_field :email,
              required: true,
              autocomplete: "email",
              placeholder: " ",
              aria: { describedby: "budget-email-error" },
              data: {
                email_validate_target: "input",
                action: "input->email-validate#validate blur->email-validate#validate"
              } %>
            <p id="budget-email-error" class="budget-form__field-error" data-email-validate-target="error" hidden>
              Digite um e-mail válido.
            </p>
          </div>
        </div>

        <div class="budget-form__grid budget-form__grid--2 budget-form__grid--top-aligned">
          <div class="budget-form__field">
            <%= f.label :state, "*Estado" %>
            <div class="custom-select custom-select--budget" data-controller="custom-select">
              <%= f.select :state,
                ["SP", "MG", "RJ", "ES", "PR", "SC", "RS", "BA", "GO", "DF", "Outro"],
                { prompt: "Selecione" },
                required: true,
                data: { custom_select_target: "select" } %>
            </div>
          </div>

          <div class="budget-form__field">
            <%= f.label :city, "*Cidade" %>
            <%= f.text_field :city, required: true, maxlength: 80 %>
          </div>
        </div>

        <div class="budget-form__field budget-form__field--full">
          <%= f.label :referral_source, "*Como nos encontrou?" %>
          <div class="custom-select custom-select--budget" data-controller="custom-select">
            <%= f.select :referral_source,
              ["Google", "Instagram", "LinkedIn", "Facebook", "Indicacao", "Cliente atual", "Outro"],
              { prompt: "Selecione" },
              required: true,
              data: { custom_select_target: "select" } %>
          </div>
        </div>

        <div class="budget-form__field budget-form__field--full">
          <%= f.label :message, "*Mensagem" %>
          <%= f.text_area :message, required: true, rows: 5 %>
        </div>

        <div class="budget-form__actions">
          <button type="submit" class="black-btn budget-form__submit" data-cnpj-mask-target="submit">ENVIAR</button>
        </div>
      <% end %>
    </div>
  </div>
</section>