<section class="about-team" aria-labelledby="about-team-heading">
  <div class="container">
    <div class="about-team__grid">
      <article class="about-team__media" aria-label="Equipe da Hiperion Serras">
        <div class="about-team__frame">
          <%= image_tag "about/equipe-2x.png",
                alt: "Equipe da Hiperion Serras reunindo especialistas com experiência em soluções de corte industrial",
                class: "about-team__image img-fluid",
                loading: "lazy" %>
        </div>
      </article>

      <article class="about-team__content" aria-labelledby="about-team-heading">
        <h2 id="about-team-heading" class="about-team__title">Nosso time</h2>
