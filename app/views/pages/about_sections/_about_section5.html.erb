<% faqs = [
  {
    question: "A Hiperion atende apenas o segmento de metais?",
    answer: "Nao. Atuamos com foco em metais e nao ferrosos, mas tambem atendemos aplicacoes em madeira, MDF, paletes e derivados, sempre com orientacao tecnica para cada processo."
  },
  {
    question: "A empresa trabalha apenas com venda de serras?",
    answer: "Nao. Alem do fornecimento de serras industriais, oferecemos afiação tecnica, manutencao, consultoria e suporte para aumentar a vida util das ferramentas e a produtividade."
  },
  {
    question: "Voces realizam analise tecnica antes de indicar uma solucao?",
    answer: "Sim. Cada recomendacao considera material, maquina, regime de corte e objetivo de producao, para indicar a melhor combinacao entre desempenho e estabilidade operacional."
  },
  {
    question: "Voces trabalham com projetos personalizados?",
    answer: "Sim. Desenvolvemos solucoes sob medida para demandas especificas, com acompanhamento tecnico e ajustes conforme a necessidade de cada operacao industrial."
  },
  {
    question: "Como funciona o processo de afiacao tecnica?",
    answer: "A afiação segue padroes tecnicos de geometria e acabamento, com avaliacao previa da ferramenta para restaurar desempenho de corte, reduzir esforco da maquina e manter qualidade final."
  },
  {
    question: "Com qual marca voces trabalham nas laminas de serra fita?",
    answer: "Trabalhamos com laminas de serra fita Eberle, reconhecidas pela qualidade alema, confiabilidade no corte e consistencia em aplicacoes industriais exigentes."
  },
  {
    question: "Qual e a area de atuacao da Hiperion?",
    answer: "Temos atuacao consolidada no Sudeste, com presenca forte em Sao Paulo, Minas Gerais e Rio de Janeiro, atendendo industrias com agilidade e suporte especializado."
  }
] %>

<section class="about-faq" aria-labelledby="about-faq-heading" data-controller="about-faq" itemscope itemtype="https://schema.org/FAQPage">
  <div class="container">
    <header class="about-faq__header">
      <h2 id="about-faq-heading" class="about-faq__title">Duvidas frequentes</h2>
      <p class="about-faq__subtitle">Antes de qualquer decisao, informacao tecnica precisa faz toda a diferenca.</p>
    </header>

    <div class="about-faq__list">
      <% faqs.each_with_index do |faq, index| %>
        <article class="about-faq__item" data-about-faq-target="item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <button
            type="button"
            class="about-faq__question"
            data-about-faq-target="button"
            data-action="click->about-faq#toggle"
            data-about-faq-index-param="<%= index %>"
            aria-expanded="false"
            aria-controls="about-faq-answer-<%= index %>"
            id="about-faq-question-<%= index %>"
          >
            <span class="about-faq__question-text" itemprop="name"><%= faq[:question] %></span>
            <span class="about-faq__icon" aria-hidden="true">+</span>
          </button>

          <div
            class="about-faq__answer"
            id="about-faq-answer-<%= index %>"
            role="region"
            aria-labelledby="about-faq-question-<%= index %>"
            data-about-faq-target="content"
            hidden
            itemscope
            itemprop="acceptedAnswer"
            itemtype="https://schema.org/Answer"
          >
            <p class="about-faq__answer-text" itemprop="text"><%= faq[:answer] %></p>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>
