<section class="circular-saws-section" id="serras-circulares" aria-labelledby="circular-saws-heading">
  <div class="circular-saws-section__grid">
    <article class="circular-saws-section__intro" aria-label="Serras circulares para diferentes aplicações industriais">
      <h2 id="circular-saws-heading" class="circular-saws-section__title">
        Serras circulares
      </h2>

      <p class="circular-saws-section__description">
        Nossas serras circulares são projetadas para atender diferentes aplicações industriais, entregam precisão no corte de metais, não ferrosos e madeira, com estabilidade e alto rendimento.
      </p>

      <%= link_to "CONHEÇA NOSSAS SERRAS CIRCULARES", circular_saw_products_path,
            class: "secondary-btn py-2 text-center",
            aria: { label: "Conheça nossas serras circulares" } %>
    </article>

    <article class="circular-saws-section__card circular-saws-section__card--metals" role="img" aria-label="Serras circulares para metais e não ferrosos">
      <div class="circular-saws-section__card-content">
        <h3 class="circular-saws-section__card-title" style="font-size: 25px;">METAIS E NAO FERROSOS</h3>
        <p class="circular-saws-section__card-description">
          Serras circulares de alta performance para aluminio, cobre, latao e ligas metalicas, com geometria precisa e estabilidade para processos industriais que nao admitem falhas.
        </p>
      </div>
    </article>

    <article class="circular-saws-section__card circular-saws-section__card--wood" role="img" aria-label="Serras circulares para madeira">
      <div class="circular-saws-section__card-content">
        <h3 class="circular-saws-section__card-title" style="font-size: 25px;">MADEIRA</h3>
        <p class="circular-saws-section__card-description">
          Serras circulares projetadas para madeira macica, MDF, paletes e derivados, garantindo acabamento limpo, maior durabilidade e produtividade continua no corte.
        </p>
      </div>
    </article>
  </div>
</section>
