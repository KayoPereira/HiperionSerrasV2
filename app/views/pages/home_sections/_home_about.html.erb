<section class="about-section" aria-labelledby="about-section-heading">
  <div class="about-section__inner">
    <div class="about-section__image-wrapper">
      <%= image_tag "homepage/section1-2x.png",
            alt: "Fachada da Hiperion Serras, empresa especialista em soluções de corte industrial",
            class: "about-section__image img-fluid",
            loading: "lazy",
            width: "615",
            height: "615" %>
    </div>

    <div class="about-section__content">
      <h2 id="about-section-heading" class="about-section__title">
        Soluções em serras circulares e afiação<br> industrial para processos de corte de<br> alta exigência
      </h2>
      <p class="about-section__description">
        Somos especialistas em serras circulares e serviços de afiação<br> industrial, atuando com foco em desempenho, precisão e<br> continuidade produtiva.
      </p>
      <%= link_to "SAIBA MAIS SOBRE NOSSA EMPRESA", about_path,
            class: "secondary-btn py-3",
            aria: { label: "Saiba mais sobre a empresa Hiperion Serras" } %>
    </div>
  </div>
</section>
