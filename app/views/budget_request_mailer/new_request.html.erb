<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f5f7fb;padding:24px 12px;font-family:Arial,sans-serif;">
  <tr>
    <td align="center">
      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:680px;background:#ffffff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">
        <tr>
          <td style="background:#1d2331;padding:26px 24px;text-align:center;">
            <% if attachments["hiperion-logo.png"].present? %>
              <%= image_tag attachments["hiperion-logo.png"].url, alt: "Hiperion Serras", width: 210, style: "display:block;margin:0 auto 14px;max-width:210px;height:auto;" %>
            <% end %>
            <h1 style="margin:0;color:#ffffff;font-size:24px;line-height:1.3;font-weight:700;">Novo pedido de orcamento recebido</h1>
            <p style="margin:10px 0 0;color:#d2ac47;font-size:14px;line-height:1.4;">A equipe comercial recebeu uma nova solicitacao pelo site.</p>
          </td>
        </tr>

        <tr>
          <td style="padding:24px;">
            <p style="margin:0 0 18px;color:#111827;font-size:15px;line-height:1.55;">
              Ola, time Hiperion. Seguem os dados enviados no formulario de orcamento:
            </p>

            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
              <tr>
                <td style="width:38%;padding:12px;border-bottom:1px solid #e5e7eb;background:#fafafa;font-weight:700;color:#111827;">CNPJ</td>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;color:#111827;"><%= @budget_request.company_tax_id %></td>
              </tr>
              <tr>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;background:#fafafa;font-weight:700;color:#111827;">Empresa</td>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;color:#111827;"><%= @budget_request.company_name %></td>
              </tr>
              <tr>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;background:#fafafa;font-weight:700;color:#111827;">Segmento</td>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;color:#111827;"><%= @budget_request.business_segment %></td>
              </tr>
              <tr>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;background:#fafafa;font-weight:700;color:#111827;">Nome</td>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;color:#111827;"><%= @budget_request.full_name %></td>
              </tr>
              <tr>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;background:#fafafa;font-weight:700;color:#111827;">Telefone</td>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;color:#111827;"><%= @budget_request.phone %></td>
              </tr>
              <tr>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;background:#fafafa;font-weight:700;color:#111827;">Email</td>
                <td style="padding:12px;border-bottom:1px solid #e5e7eb;color:#111827;"><%= @budget_request.email %></td>
              </tr>
              <tr>
                <td style="padding:12px;background:#fafafa;font-weight:700;color:#111827;">Como nos encontrou</td>
                <td style="padding:12px;color:#111827;"><%= @budget_request.referral_source %></td>
              </tr>
            </table>

            <div style="margin-top:18px;padding:14px;border-left:4px solid #d2ac47;background:#fffdf6;">
              <p style="margin:0 0 8px;color:#111827;font-weight:700;">Mensagem</p>
              <div style="margin:0;color:#1f2937;line-height:1.6;"><%= simple_format(@budget_request.message) %></div>
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>